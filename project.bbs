# Using my own build system: https://github.com/luppichristian/bbs

id(c3d)
name("C3D")
ver(0.1.0)

configs(debug release)

targets(
  dyn_lib(
    id(c3d_lib)
    lang(cuda)
    cuda_architectures("75" "89")
    include_dirs(inc)
    units(src/*.cu)
    defines(C3D_EXPORT_LIB)
  )

  consoleless(
    id(c3d_test)
    lang(c)
    include_dirs(inc)
    units(test/main.c)
    dependencies(c3d_lib)
  )
)
